<?php
require_once 'config.php';

$data = json_decode(file_get_contents('php://input'), true);

if (empty($data['id'])) {
    echo json_encode(['success' => false, 'message' => 'معرف المنتج مطلوب']);
    exit();
}

try {
    $stmt = $pdo->prepare("UPDATE products SET 
                           barcode = ?, name = ?, description = ?, purchase_price = ?, 
                           selling_price = ?, quantity = ?, min_quantity = ?, expiry_date = ?, category = ? 
                           WHERE id = ?");
    $stmt->execute([
        $data['barcode'],
        $data['name'],
        $data['description'] ?? '',
        $data['purchase_price'],
        $data['selling_price'],
        $data['quantity'] ?? 0,
        $data['min_quantity'] ?? 5,
        $data['expiry_date'] ?? null,
        $data['category'] ?? '',
        $data['id']
    ]);
    
    echo json_encode(['success' => true, 'message' => 'تم تحديث المنتج بنجاح']);
    
} catch(PDOException $e) {
    echo json_encode(['success' => false, 'message' => 'خطأ: ' . $e->getMessage()]);
}
?>
